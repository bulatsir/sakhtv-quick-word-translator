{
  "manifest_version": 3,
  "name": "SakhTV Quick Word Translator",
  "version": "0.5.0",
  "description": "Перевод слов в субтитрах sakh.tv и Netflix по наведению мыши (en → ru)",
  "content_scripts": [
    {
      "matches": [
        "https://sakh.tv/watch/*",
        "https://www.sakh.tv/watch/*",
        "https://sakh.tv/movie/watch/*",
        "https://www.sakh.tv/movie/watch/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css", "styles-sakhtv.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.netflix.com/*",
        "https://netflix.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css", "styles-netflix.css"],
      "run_at": "document_idle"
    }
  ],
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": ["https://translate.googleapis.com/*"]
}
